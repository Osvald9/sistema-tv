{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/player/:id",
      "destination": "/public/player/index.html"
    },
    {
      "source": "/admin",
      "destination": "/public/admin/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/public/admin/:path*"
    },
    {
      "source": "/config.js",
      "destination": "/public/config.js"
    },
    {
      "source": "/player/:path*",
      "destination": "/public/player/:path*"
    },
    {
      "source": "/",
      "destination": "/public/admin/index.html"
    }
  ]
}
